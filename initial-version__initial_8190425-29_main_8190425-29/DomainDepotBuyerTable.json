          "desc": {
            "type": "i18n",
            "changedLocales": {
              "BR": {
                "oldText": "Agente do Departamento de Segurança do STUT em Vale IV.",
                "newText": "As entregas devem atender às regulamentações de gerenciamento de suprimentos do STUT. Obrigada."
              },
              "CN": {
                "oldText": "联盟工团四号谷地安全局特工。",
                "newText": "请按联盟工团物资管理规范配送货物。谢谢。"
              },
              "DE": {
                "oldText": "Agent des GBT-Sicherheitsbüros in Tal IV.",
                "newText": "Lieferungen sollten den Vorschriften der Vorratsverwaltung des GBT entsprechen. Danke."
              },
              "EN": {
                "oldText": "UWST Security Bureau Agent at Valley IV.",
                "newText": "Deliveries should comply with UWST supplies management regulations. Thank you."
              },
              "FR": {
                "oldText": "Membre de l'agence de sécurité du STUT dans la Vallée-IV.",
                "newText": "Toute livraison doit respecter la réglementation en vigueur sur la gestion des marchandises du STUT. Merci."
              },
              "ID": {
                "oldText": "Agen Biro Sekuriti UWST di Lembah IV.",
                "newText": "Pengiriman harus mematuhi peraturan manajemen pasokan UWST. Terima kasih."
              },
              "IT": {
                "oldText": "Agente del Dipartimento di sicurezza dell'USLT presso Valle IV.",
                "newText": "Le consegne devono essere conformi ai regolamenti dell'USLT sulla gestione dei rifornimenti. Grazie."
              },
              "JP": {
                "oldText": "工業団連盟四号谷地の保安局エージェント。",
                "newText": "工業団連盟の物資管理規範通りに配達してください。ありがとうございます。"
              },
              "KR": {
                "oldText": "연맹 공단 4번 협곡 안전국 요원.",
                "newText": "연맹 공단 물자 관리 규정에 맞춰서 운송해 주시기 바랍니다. 좋은 하루 보내세요."
              },
              "MX": {
                "oldText": "Agente de la agencia de Seguridad del S.T.U.T. en Valle IV.",
                "newText": "Las entregas deben cumplir con las normas de gestión de suministros de los S.T.U.T. Gracias."
              },
              "RU": {
                "oldText": "Агент бюро безопасности СОРТ в Долине IV.",
                "newText": "Поставки должны соответствовать правилам распоряжения припасами СОРТ. Спасибо."
              },
              "TC": {
                "oldText": "聯盟工團四號谷地安全局特務。",
                "newText": "請按聯盟工團物資管理規範配送貨物。謝謝。"
              },
              "TH": {
                "oldText": "เจ้าหน้าที่​สำนักงาน​รักษา​ความปลอดภัย​ของ​ UWST ประจำ​หุบเขา​ IV",
                "newText": "การจัดส่ง​ควร​เป็นไปตาม​ระเบียบการ​จัดการ​พัสดุ​ของ​ UWST ขอบคุณ"
              },
              "VN": {
                "oldText": "Đặc vụ Cục An Ninh Công Đoàn tại Thung Lũng IV.",
                "newText": "Hàng hóa chuyển giao phải tuân thủ quy định quản lý vật tư của Đại Công Đoàn Talos II. Xin cảm ơn."
              }
            }
