          "desc": {
            "type": "i18n",
            "changedLocales": {
              "BR": {
                "oldText": "Cirurgião na Clínica da Área de Mineração. Casos graves recebem tratamento prioritário.",
                "newText": "Termine seus outros pedidos primeiro. Eu posso esperar, mas não demore muito."
              },
              "CN": {
                "oldText": "矿区医疗站医生。重伤应优先处理。",
                "newText": "您可以先送其他订单，我等您，只要稍微快点就好。"
              },
              "DE": {
                "oldText": "Chirurg in der Bergbauklinik. Schwere Fälle haben Vorrang.",
                "newText": "Schließe zuerst deine anderen Aufträge ab. Ich kann warten, aber lass dir nicht zu viel Zeit."
              },
              "EN": {
                "oldText": "Surgeon at the Mining Area Clinic. Serious cases get priority treatment.",
                "newText": "Finish your other orders first. I can wait, but don't take too long."
              },
              "FR": {
                "oldText": "Chirurgien à la clinique de la zone d'extraction. Les cas les plus graves sont traités en priorité.",
                "newText": "Finissez d'abord vos commandes. Je peux attendre, mais ne traînez pas."
              },
              "ID": {
                "oldText": "Ahli bedah di Klinik Area Tambang. Cedera yang serius akan diprioritaskan.",
                "newText": "Selesaikan dulu pesananmu yang lain. Aku bisa menunggu, tapi jangan terlalu lama."
              },
              "IT": {
                "oldText": "Chirurgo presso l'Ambulatorio della miniera. I casi più gravi hanno sempre la precedenza.",
                "newText": "Dai priorità agli altri ordini, io posso aspettare. Non metterci troppo, però."
              },
              "JP": {
                "oldText": "鉱区診療所の医師。重傷を優先的に処置すべし。",
                "newText": "他の配達を先にどうぞ。無理のない範囲で早めに送っていただければいいので、待っています。"
              },
              "KR": {
                "oldText": "광산 지역 의료소 의사입니다. 언제나... 중상자를 최우선으로!",
                "newText": "안 급하니까, 한집 운송 안 하셔도 돼요. 기다리고 있을 테니까요. 그래도 너무 돌아오진 마세요."
              },
              "MX": {
                "oldText": "Cirujano en la Clínica de la zona minera. Los casos graves tienen tratamiento prioritario.",
                "newText": "Termina primero tus otros pedidos. Puedo esperar, pero no tardes mucho."
              },
              "RU": {
                "oldText": "Хирург в шахтерском медпункте. Сначала займусь тяжелоранеными.",
                "newText": "Сначала выполни другие заказы. Я могу подождать, но не затягивай."
              },
              "TC": {
                "oldText": "礦區醫療站醫生。重傷應優先處理。",
                "newText": "您可以先送其他訂單，我等您，只要稍微快點就好。"
              },
              "TH": {
                "oldText": "ศัลยแพทย์​ที่​คลินิก​พื้นที่​ขุด​เหมือง​ เคส​รุนแรง​จะ​ได้รับ​การรักษา​แบบ​เร่งด่วน​ก่อน",
                "newText": "ไป​ทำ​ออ​เดอร์​อื่น​ของ​คุณ​ให้​เสร็จ​ก่อน​เถอะ​ ฉัน​รอ​ได้​ แต่​อย่า​นาน​เกินไป​ล่ะ"
              },
              "VN": {
                "oldText": "Bác sĩ phẫu thuật tại Phòng Y Tế Khu Mỏ. Các ca nghiêm trọng sẽ được ưu tiên điều trị.",
                "newText": "Trước tiên, hãy hoàn thành đơn hàng khác của bạn. Tôi đợi được, nhưng đừng lâu quá."
              }
            }
          },
          "headIcon": {
            "type": "value",
            "oldValue": "icon_buyer_1006_yueyisheng",
            "newValue": "icon_buyer_1006_mataiao"
          }
        }
      },
