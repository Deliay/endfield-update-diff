          "desc": {
            "type": "i18n",
            "changedLocales": {
              "BR": {
                "oldText": "Diretora, Unidade de Produção de Aplicações e Tecnologia de Xiranita de Wuling.",
                "newText": "Se você tiver tempo, tome um chá antes de sair."
              },
              "CN": {
                "oldText": "武陵息壤应用与技术生产单位的负责人。",
                "newText": "要是方便的话，喝杯茶再走吧。"
              },
              "DE": {
                "oldText": "Direktorin der Wuling-Einheit für Xiranit-Anwendungen und Tech-Produktion.",
                "newText": "Wenn du Zeit hast, trink doch etwas Tee, bevor du gehst."
              },
              "EN": {
                "oldText": "Director, Wuling Xiranite Application and Tech Production Unit.",
                "newText": "If you got the time, have some tea before you leave."
              },
              "FR": {
                "oldText": "Directrice de l'unité de production technologique et d'application de la xiranite de Wuling",
                "newText": "Si vous avez le temps, prenez donc un thé avant de partir."
              },
              "ID": {
                "oldText": "Direktur, Unit Produksi dan Penerapan Teknologi Xiranite Wuling.",
                "newText": "Kalau sempat, minumlah teh dulu sebelum pergi."
              },
              "IT": {
                "oldText": "Direttrice dell'unità Applicazioni e Produzione tecnologica della xiranite di Wuling.",
                "newText": "Se hai tempo, prendi una tazza di tè prima di andare via."
              },
              "JP": {
                "oldText": "武陵息壌応用技術生産機関責任者。",
                "newText": "よければ、お茶でもどうですか。"
              },
              "KR": {
                "oldText": "무릉 식양 응용 및 기술 생산 기구 책임자.",
                "newText": "괜찮으시면 차 한잔하고 가실래요?"
              },
              "MX": {
                "oldText": "Directora, Asolada Unidad de Producción de Tecnología y Aplicación de Xiranita Wuling.",
                "newText": "Si tienes tiempo, toma un poco de té antes de irte."
              },
              "RU": {
                "oldText": "Директор, отдел применения ксиранита и технического производства Улина.",
                "newText": "Если есть время, выпей чаю перед уходом."
              },
              "TC": {
                "oldText": "武陵息壤應用與技術生產部的負責人。",
                "newText": "要是方便的話，喝杯茶再走吧。"
              },
              "TH": {
                "oldText": "ผู้อำนวยการ​ แผนก​เทคโนโลยี​การผลิต​และ​การ​ประยุกต์ใช้​งาน​ซี​เรน​ไนต์​แห่ง​อู่​หลิง",
                "newText": "ถ้า​มี​เวลา​ ก็​ดื่ม​ชา​สักหน่อย​ก่อน​กลับ​สิ"
              },
              "VN": {
                "oldText": "Giám Đốc, Đơn Vị Ứng Dụng Và Sản Xuất Công Nghệ Xiranite Võ Lăng.",
                "newText": "Nếu có thời gian, hãy uống chút trà trước khi rời đi."
              }
            }
          },
